# Django Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=True

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_SESSION_TOKEN=leave_blank_if_not_using_temp_creds
AWS_REGION=us-east-1

# S3 — Document Storage
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name

# SNS — Notifications
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:xxxxxxxxxxxx:YourTopicName

# DynamoDB — Audit Logs
AWS_DYNAMODB_TABLE_NAME=DocumentApprovalLogs

# Cognito — User Authentication
AWS_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
AWS_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Lambda — Background Automation
AWS_LAMBDA_FUNCTION_NAME=ProcessDocumentApproval
