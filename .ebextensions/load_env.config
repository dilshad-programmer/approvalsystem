files:
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/load_dotenv.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Source .env file into the EB environment if it exists
      ENV_FILE="/var/app/current/.env"
      if [ -f "$ENV_FILE" ]; then
        set -o allexport
        source "$ENV_FILE"
        set +o allexport
        echo "[$( date )] .env loaded successfully" >> /var/log/eb-hooks.log
      else
        echo "[$( date )] WARNING: .env file not found at $ENV_FILE" >> /var/log/eb-hooks.log
      fi
